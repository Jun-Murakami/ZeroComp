-    struct WebKitAndDependencyLibraryNames
+    // MixCompare patch: resolve a library by its API-generation base name (e.g.
+    // "libwebkit2gtk-4.1") WITHOUT hardcoding the SONAME number. Upstream JUCE only tries
+    // the unversioned "<base>.so", which on Fedora/Debian exists solely in the -devel/-dev
+    // packages, so end-user machines fail every dlopen and the webview never starts (blank
+    // UI). We try, in order:
+    //   1) "<base>.so"                 -- the devel symlink, if present
+    //   2) "<base>.so.<N>" discovered by scanning the standard library directories, highest
+    //      N first -- the SONAME the runtime package actually ships.
+    // Only the generation base (4.1 = libsoup3 world / 4.0 = libsoup2 world) is hardcoded;
+    // it names an ABI generation and must be known. The trailing SONAME number is discovered
+    // at runtime, so a future SONAME bump needs no code change.
+    static DylibHandle openLibraryByBase (const String& base, int flags = RTLD_NOW | RTLD_LOCAL)
     {
-        const char* webkitLib;
-        const char* jsLib;
-        const char* soupLib;
+        if (auto handle = DylibHandle ((base + ".so").toRawUTF8(), flags))
+            return handle;
+
+        struct Candidate { int soVersion; String path; };
+        std::vector<Candidate> candidates;
+
+        for (auto* dirPath : { "/usr/lib64", "/usr/lib/x86_64-linux-gnu",
+                               "/usr/lib", "/lib64", "/usr/local/lib" })
+        {
+            const File dir { dirPath };
+
+            if (! dir.isDirectory())
+                continue;
+
+            for (const auto& file : dir.findChildFiles (File::findFiles, false, base + ".so.*"))
+            {
+                // Keep only "<base>.so.<digits>" (the bare SONAME); skip fully-versioned
+                // files like "<base>.so.0.1.0".
+                const auto suffix = file.getFileName().fromLastOccurrenceOf (".so.", false, false);
+
+                if (suffix.isNotEmpty() && suffix.containsOnly ("0123456789"))
+                    candidates.push_back ({ suffix.getIntValue(), file.getFullPathName() });
+            }
+        }
+
+        std::sort (candidates.begin(), candidates.end(),
+                   [] (const Candidate& a, const Candidate& b) { return a.soVersion > b.soVersion; });
+
+        for (const auto& candidate : candidates)
+            if (auto handle = DylibHandle (candidate.path.toRawUTF8(), flags))
+                return handle;
+
+        return {};
+    }
