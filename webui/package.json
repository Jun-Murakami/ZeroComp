{
  "name": "zerocomp-webui",
  "private": true,
  "version": "1.1.7",
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-web-demos.cjs",
    "dev": "vite",
    "predev:web": "node scripts/sync-web-demos.cjs",
    "dev:web": "vite --config vite.config.web.ts",
    "prebuild": "node scripts/sync-web-demos.cjs && license-checker --production --json --out src/assets/licenses.json",
    "build": "tsc -b && vite build",
    "prebuild:web": "node scripts/sync-web-demos.cjs",
    "build:web": "vite build --config vite.config.web.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:web": "vite preview --config vite.config.web.ts",
    "licenses": "license-checker --production --json --out src/assets/licenses.json",
    "sync-web-demos": "node scripts/sync-web-demos.cjs",
    "deploy:web": "npm run build:web && firebase deploy --only hosting"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/jost": "^5.2.8",
    "@fontsource/red-hat-mono": "^5.2.8",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "juce-framework-frontend-mirror": "^8.0.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "license-checker": "^25.0.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3"
  }
}
